# Gemini (agents)
GEMINI_API_KEY=...

# Hedera — Orchestrator account
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=302e020100300506032b6570...

# Hedera — Escrow account
HEDERA_ESCROW_ACCOUNT_ID=0.0.yyyyy
HEDERA_ESCROW_PRIVATE_KEY=302e020100300506032b6570...

# Hedera — General
HEDERA_NETWORK=testnet
HEDERA_AUDIT_TOPIC_ID=0.0.zzzzz

# Hedera — Payout routing (agent recipient accounts)
# Values below are placeholders. Use real, existing account IDs on the
# selected network (testnet/mainnet), not random numbers.
# If agent-specific account is missing, code falls back to:
# HEDERA_OPERATOR_PAYOUT_ACCOUNT_ID -> HEDERA_ACCOUNT_ID
HEDERA_OPERATOR_PAYOUT_ACCOUNT_ID=0.0.12345

# Hedera — Payout controls
# Example: 1 USD ~= 0.01 HBAR (testnet/demo)
HEDERA_USD_TO_HBAR_RATE=0.01
# Per payout cap (HBAR) to avoid draining balance during tests
HEDERA_MAX_PAYOUT_HBAR=0.01
